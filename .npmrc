# Routes the @libstake scope to GitHub Packages.
# Auth token is NOT stored here: pnpm 10/11 no longer expands env vars in a
# repo-committed .npmrc. Set it in user-level config instead, e.g.
#   pnpm config set "//npm.pkg.github.com/:_authToken" <TOKEN>
# In CI, actions/setup-node (registry-url + NODE_AUTH_TOKEN) handles it.
@libstake:registry=https://npm.pkg.github.com
