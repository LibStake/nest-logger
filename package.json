{
  "name": "@libstake/nest-logger",
  "version": "0.1.0",
  "description": "NestJS Winston logger with OpenTelemetry OTLP log export and trace correlation",
  "license": "MIT",
  "author": "LibStake",
  "packageManager": "pnpm@10.34.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibStake/nest-logger.git"
  },
  "homepage": "https://github.com/LibStake/nest-logger#readme",
  "bugs": {
    "url": "https://github.com/LibStake/nest-logger/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "winston": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/exporter-logs-otlp-grpc": {
      "optional": true
    },
    "@opentelemetry/exporter-logs-otlp-http": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@opentelemetry/winston-transport": "^0.29.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "winston": "^3.19.0"
  }
}
